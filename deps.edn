{:paths ["src"]

 :deps {funcool/promesa {:mvn/version "11.0.678"}}

 :aliases
 {:dev {:extra-deps {org.clojure/clojure       {:mvn/version "1.12.1"}
                     org.clojure/clojurescript {:mvn/version "1.12.42"}}}

  :test {:extra-paths ["test"]}

  ;; clojure -M:outdated --upgrade
  :outdated {:extra-deps {com.github.liquidz/antq {:mvn/version "2.11.1276"}}
             :main-opts  ["-m" "antq.core"]}

  ;; clojure -M:nrepl — JVM nREPL for editor tooling
  :nrepl {:extra-paths ["test"]
          :extra-deps  {nrepl/nrepl {:mvn/version "1.3.1"}}
          :jvm-opts    ["-Djdk.attach.allowAttachSelf"]
          :main-opts   ["-m" "nrepl.cmdline" "--port" "7888"]}

  ;; clojure -X:jar
  :jar {:replace-deps {com.github.seancorfield/depstar {:mvn/version "2.1.303"}}
        :exec-fn      hf.depstar/jar
        :exec-args    {:sync-pom    true
                       :group-id    "io.github.snits"
                       :artifact-id "cljs-claude"
                       :version     "0.1.0-SNAPSHOT"
                       :jar         "cljs-claude.jar"}}

  ;; CLOJARS_USERNAME=... CLOJARS_PASSWORD=... clojure -X:deploy
  :deploy {:extra-deps {slipset/deps-deploy {:mvn/version "0.2.2"}}
           :exec-fn    deps-deploy.deps-deploy/deploy
           :exec-args  {:installer :remote
                        :artifact  "cljs-claude.jar"}}}}
